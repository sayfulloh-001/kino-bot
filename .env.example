# Telegram Bot Token (from @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin Telegram IDs (separated by comma if multiple: e.g. 123456789,987654321)
ADMIN_ID=123456789

# Mandatory channels for subscription check (separated by comma)
